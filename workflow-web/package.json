{
  "name": "workflow-web",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "preview": "vite preview",
    "test:unit": "node src/utils/__tests__/calcEngine.spec.js && node src/utils/__tests__/flowConditionGroups.spec.js",
    "test:form-node-schema": "node src/shared/__tests__/form-node-property-schema.spec.js",
    "test:integration": "node --loader ./scripts/test-alias-loader.mjs src/__tests__/runtime-integration.spec.js",
    "test:page-config": "node src/__tests__/page-config-audit.spec.js",
    "test": "npm run test:unit && npm run test:form-node-schema && npm run test:integration && npm run test:functional && npm run test:page-config && npm run test:ui-config",
    "test:ui-config": "node scripts/ui-config-audit.mjs",
    "test:e2e:mock": "npm run build && node scripts/e2e-mock-pages.mjs",
    "test:functional": "node --loader ./scripts/test-alias-loader.mjs src/__tests__/functional.spec.js",
    "test:real-ui-config": "node scripts/real-ui-config-release.mjs",
    "test:visual:real": "node scripts/visual-acceptance-real.mjs",
    "test:workflow:real": "node scripts/e2e-real-workflow.mjs",
    "test:workflow:config-real": "node scripts/real-workflow-config-closure.mjs",
    "test:workflow:node-forms-real": "node scripts/real-workflow-node-forms.mjs",
    "test:workflow:actions-real": "node scripts/real-flow-action-timing.mjs",
    "test:demo:real": "node scripts/real-dynamic-extension-demo.mjs"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@element-plus/icons-vue": "^2.3.0",
    "axios": "^1.6.0",
    "bpmn-auto-layout": "^1.2.0",
    "bpmn-js": "^17.0.0",
    "bpmn-js-properties-panel": "1.21.0",
    "codemirror": "^6.0.2",
    "dayjs": "^1.11.0",
    "diagram-js": "^14.0.0",
    "element-plus": "^2.5.0",
    "pinia": "^2.1.0",
    "vue": "^3.4.0",
    "vue-codemirror": "^6.1.1",
    "vue-router": "^4.2.0",
    "vuedraggable": "^4.1.0",
    "xml-formatter": "^3.7.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.6.2",
    "sass": "^1.70.0",
    "vite": "4.5.0"
  }
}
