<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.workflow.mapper.ProcessCommonOpinionMapper">

    <!-- 查询用户的常用意见 -->
    <select id="findByUserId" resultType="com.workflow.entity.ProcessCommonOpinion">
        SELECT * FROM process_common_opinion
        WHERE user_id = #{userId}
        <if test="opinionType != null and opinionType != ''">
            AND opinion_type = #{opinionType}
        </if>
        ORDER BY use_count DESC, created_at DESC
    </select>

</mapper>
